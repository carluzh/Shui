---
import Calendar from './Calendar.astro';
import MonthlyCalendar from './MonthlyCalendar.astro';
---

<div class="flex-grow calendar-widget">
  <div class="flex justify-end mb-1">
    <button id="expand-toggle" class="view-toggle" data-view="weekly">Expand</button>
  </div>
  <div class="border bg-muted/30 rounded-md transition-all hover:shadow-md hover:border-primary/50 calendar-container">
    <div id="calendar-container">
      <div id="weekly-view" class="p-4">
        <Calendar view="weekly" />
      </div>
      <div id="monthly-view" class="p-4 pb-2 hidden">
        <MonthlyCalendar />
      </div>
    </div>
  </div>
</div>

<style>
  .view-toggle {
    font-size: 0.75rem;
    font-weight: 400;
    padding: 1px 2px;
    color: hsl(var(--muted-foreground));
    transition: all 0.2s ease-in-out;
    background: none;
    border: none;
    cursor: pointer;
    position: relative;
  }

  .view-toggle.active {
    font-weight: 500;
    text-decoration: underline;
  }

  .view-toggle:hover {
    color: hsl(var(--primary));
  }
</style>

<script>
  function setupCalendarToggle() {
    const weeklyView = document.getElementById('weekly-view');
    const monthlyView = document.getElementById('monthly-view');
    const expandToggle = document.getElementById('expand-toggle');

    if (!weeklyView || !monthlyView || !expandToggle) {
      console.warn('One or more required elements not found for calendar toggle');
      return;
    }

    let currentView = 'weekly';

    function updateCalendarView(view: 'weekly' | 'monthly') {
      const weeklyView = document.getElementById('weekly-view');
      const monthlyView = document.getElementById('monthly-view');
      const expandToggle = document.getElementById('expand-toggle');
      
      if (weeklyView && monthlyView && expandToggle) {
        if (view === 'weekly') {
          weeklyView.classList.remove('hidden');
          monthlyView.classList.add('hidden');
          expandToggle.textContent = 'Expand';
          expandToggle.classList.remove('active');
        } else {
          weeklyView.classList.add('hidden');
          monthlyView.classList.remove('hidden');
          expandToggle.textContent = 'Collapse';
          expandToggle.classList.add('active');
        }
      }
    }

    expandToggle.addEventListener('click', () => {
      currentView = currentView === 'weekly' ? 'monthly' : 'weekly';
      updateCalendarView(currentView);
    });

    // Initialize view (no need to call updateCalendarView here)
  }

  function initializeCalendar() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupCalendarToggle);
    } else {
      setupCalendarToggle();
    }
  }

  // Run on initial load and after Astro page transitions
  initializeCalendar();
  document.addEventListener('astro:page-load', initializeCalendar);
</script>
