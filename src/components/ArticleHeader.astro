---
interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<div class="mb-8">
  <div class="flex items-center mb-4 -ml-24">
    <a href="/" class="flex items-center text-sm text-muted-foreground hover:text-foreground transition-colors mr-8 w-16">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mr-2"
      >
        <path d="M6 8L2 12L6 16"></path>
        <path d="M2 12H22"></path>
      </svg>
      Back
    </a>
    
    <div class="flex-grow flex flex-col sm:flex-row sm:items-baseline sm:justify-between">
      <h1 class="text-xl font-bold sm:text-2xl md:text-3xl mb-1 sm:mb-0">
        {title}
      </h1>
      <p class="text-muted-foreground text-xs sm:text-sm text-right">
        {formattedDate}
      </p>
    </div>
  </div>

  <div class="border-b border-muted-foreground/20"></div>
</div>
